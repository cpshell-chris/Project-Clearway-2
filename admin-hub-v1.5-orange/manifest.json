{
  "manifest_version": 3,
  "name": "Administrative Hub - Cardinal Plaza Shell",
  "version": "1.5.2",
  "description": "Administrative tools for Cardinal Plaza Shell management",
  "permissions": [
    "storage",
    "sidePanel",
    "tabs",
    "activeTab"
  ],
  "host_permissions": [
    "https://api.anthropic.com/*",
    "https://sandbox.tekmetric.com/*",
    "https://shop.tekmetric.com/*",
    "https://*.run.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Administrative Hub"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://sandbox.tekmetric.com/*",
        "https://shop.tekmetric.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}