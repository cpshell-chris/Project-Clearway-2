{
  "manifest_version": 3,
  "name": "Service Advisor Hub - Cardinal Plaza Shell",
  "version": "3.16.6",
  "description": "Unified service advisor toolkit: Knowledge Assistant, Scheduling Wizard, Vehicle Consultant Advisor, and Service Developer",
  "permissions": [
    "storage",
    "sidePanel",
    "tabs",
    "activeTab"
  ],
  "host_permissions": [
    "https://api.anthropic.com/*",
    "https://sandbox.tekmetric.com/*",
    "https://shop.tekmetric.com/*",
    "https://advance-appointment-service-361478515851.us-east4.run.app/*",
    "https://*.run.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Service Advisor Hub"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://sandbox.tekmetric.com/*",
        "https://shop.tekmetric.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}